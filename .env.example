# 复制为 .env 后由 docker compose 自动加载（勿提交 .env 入库）
#
# Maven 本地仓库根目录，须与 settings.xml 里 <localRepository> 一致（该目录下直接有 io、org 等）。
#
# 默认仓库（可不写，compose-up 脚本会回退到用户目录下 .m2/repository）:
# MAVEN_LOCAL_REPOSITORY=C:/Users/你的用户名/.m2/repository
#
# 自定义路径示例（Windows）:
MAVEN_LOCAL_REPOSITORY=D:/Java/mvn_repo
#
# 与外部已启动的 Nacos 共用的 Docker 网络名
# DOCKER_NETWORK=my-network

MAVEN_LOCAL_REPOSITORY=
DOCKER_NETWORK=my-network
